@model VirtualPatDiagnosis.Models.UserAccount

@{
    ViewData["Title"] = "註冊";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<div class="container mt-5" style="max-width: 500px;">
    <div class="card shadow p-4">
        <h3 class="text-center mb-4">建立新帳號</h3>

        <form asp-action="Register" method="post">
            <div class="mb-3">
                <label asp-for="Username" class="form-label">帳號</label>
                <input asp-for="Username" class="form-control" required />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">密碼</label>
                <input asp-for="Password" type="password" class="form-control" required />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">確認密碼</label>
                <input name="ConfirmPassword" type="password" class="form-control" required />
            </div>

            <div class="mb-3">
                <label asp-for="DisplayName" class="form-label">暱稱</label>
                <input asp-for="DisplayName" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Role" class="form-label">角色</label>
                <select asp-for="Role" class="form-select">
                    <option value="student">學生</option>
                    <option value="teacher">教師</option>
                    <option value="admin">管理員</option>
                </select>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-success">註冊</button>
                <a asp-action="Login" class="btn btn-outline-secondary">返回登入</a>
            </div>
        </form>

        @if (ViewBag.Msg != null)
        {
            <div class="alert alert-danger mt-3 text-center">
                @ViewBag.Msg
            </div>
        }
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
